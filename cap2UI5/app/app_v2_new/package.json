{
  "name": "app_v2",
  "version": "0.0.1",
  "description": "Modern UI5 2.x application (legacy-free)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "ui5 serve --open index.html --sap-csp-policies --serve-csp-reports",
