<mvc:View
	controllerName="ui5_v2.controller.Main"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc">
	<Page id="mainPage" title="{i18n>appTitle}">
		<content>
			<VBox class="sapUiLargeMargin" alignItems="Start">
				<Title text="{i18n>welcomeTitle}" level="H1" class="sapUiSmallMarginBottom"/>
				<Text text="{i18n>welcomeText}" class="sapUiSmallMarginBottom"/>

				<Panel headerText="{i18n>deviceInfoHeader}" class="sapUiMediumMarginTop" width="auto">
					<content>
						<HBox class="sapUiSmallMargin" alignItems="Center">
							<core:Icon src="sap-icon://desktop-mobile" size="1.5rem" class="sapUiTinyMarginEnd"/>
							<Text text="{= ${device>/system/desktop} ? ${i18n>deviceDesktop} : ${device>/system/tablet} ? ${i18n>deviceTablet} : ${i18n>devicePhone} }"/>
						</HBox>
					</content>
				</Panel>

				<Button
					id="sayHelloButton"
					text="{i18n>sayHelloButton}"
					type="Emphasized"
					icon="sap-icon://hello-world"
					press=".onSayHello"
					class="sapUiMediumMarginTop"/>
			</VBox>
		</content>
	</Page>
</mvc:View>
